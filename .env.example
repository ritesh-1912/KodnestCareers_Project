# Database
DATABASE_URL=postgresql://kodnest:kodnest@localhost:5432/kodnestcareers?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# Application
NODE_ENV=development
PORT=3000
WORKER_PORT=3001

# Auth
NEXTAUTH_SECRET=your-secret-key-here
NEXTAUTH_URL=http://localhost:3000

# AI Providers
OPENROUTER_API_KEY=
GROQ_API_KEY=
HUGGINGFACE_API_KEY=

# Email (Mailpit)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@kodnestcareers.local

# Storage
STORAGE_TYPE=local
STORAGE_PATH=./tmp/storage

# Feature Flags
ENABLE_AI_JOBS=true
ENABLE_ANALYTICS=true
